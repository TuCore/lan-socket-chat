<Window x:Class="ChatDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Chat App" Height="600" Width="500"
        MinHeight="400" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Row 0: Connection bar -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Nickname bar -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Status bar -->
            <RowDefinition Height="Auto"/>
            <!-- Row 3: Chat display area (fills remaining space) -->
            <RowDefinition Height="*"/>
            <!-- Row 4: Message input bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Connection settings -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Content="IP:" Margin="0,0,4,0"/>
            <TextBox Grid.Column="1" x:Name="txtIP" Text="127.0.0.1" Margin="0,0,8,0"/>
            <Label Grid.Column="2" Content="Port:" Margin="0,0,4,0"/>
            <TextBox Grid.Column="3" x:Name="txtPort" Text="9000" Margin="0,0,8,0"/>
            <Button Grid.Column="4" x:Name="btnConnect" Content="Connect" 
                    Click="BtnConnect_Click" Width="90"/>
        </Grid>

        <!-- Row 1: Nickname input -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Content="Nickname:" Margin="0,0,4,0"/>
            <TextBox Grid.Column="1" x:Name="txtNickname" Text="User" />
        </Grid>

        <!-- Row 2: Status indicator -->
        <Border Grid.Row="2" Margin="0,0,0,6" Padding="6,4" 
                Background="#F0F0F0" CornerRadius="3">
            <TextBlock x:Name="lblStatus" Text="Disconnected" 
                       Foreground="Gray" FontSize="12"/>
        </Border>

        <!-- Row 3: Chat messages display -->
        <ListBox Grid.Row="3" x:Name="lstMessages" Margin="0,0,0,6"
                 FontSize="13" FontFamily="Segoe UI, Segoe UI Emoji"
                 BorderBrush="#CCC" BorderThickness="1"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="IsHitTestVisible" Value="False"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Row 4: Message input + Send button -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="btnEmoji" Content="😊" Width="36" Margin="0,0,4,0" 
                    IsEnabled="False" Click="BtnEmoji_Click" ToolTip="Emojis" Padding="0"
                    FontFamily="Segoe UI Emoji" FontSize="18" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
            
            <Popup x:Name="popEmoji" PlacementTarget="{Binding ElementName=btnEmoji}" Placement="Top" StaysOpen="False">
                <Border Background="White" BorderBrush="LightGray" BorderThickness="1" Padding="5">
                    <WrapPanel Width="150">
                        <WrapPanel.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Width" Value="30"/>
                                <Setter Property="Height" Value="30"/>
                                <Setter Property="FontSize" Value="18"/>
                                <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </WrapPanel.Resources>
                        <Button Content="😀" Click="Emoji_Click"/>
                        <Button Content="😂" Click="Emoji_Click"/>
                        <Button Content="😊" Click="Emoji_Click"/>
                        <Button Content="😍" Click="Emoji_Click"/>
                        <Button Content="👍" Click="Emoji_Click"/>
                        <Button Content="❤️" Click="Emoji_Click"/>
                        <Button Content="🔥" Click="Emoji_Click"/>
                        <Button Content="🎉" Click="Emoji_Click"/>
                        <Button Content="😎" Click="Emoji_Click"/>
                        <Button Content="🤔" Click="Emoji_Click"/>
                        <Button Content="😢" Click="Emoji_Click"/>
                        <Button Content="😡" Click="Emoji_Click"/>
                        <Button Content="✨" Click="Emoji_Click"/>
                        <Button Content="🚀" Click="Emoji_Click"/>
                        <Button Content="💯" Click="Emoji_Click"/>
                    </WrapPanel>
                </Border>
            </Popup>

            <TextBox Grid.Column="1" x:Name="txtMessage" Margin="0,0,8,0"
                     IsEnabled="False" KeyDown="TxtMessage_KeyDown" MaxLength="500"/>
            <Button Grid.Column="2" x:Name="btnSend" Content="Send" Width="80"
                    IsEnabled="False" Click="BtnSend_Click"/>
        </Grid>
    </Grid>
</Window>
